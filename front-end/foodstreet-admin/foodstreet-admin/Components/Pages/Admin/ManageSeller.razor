@page "/admin/manage-seller"
@layout AdminLayout
@rendermode InteractiveServer
@inject StoreService StoreSvc
@inject ISnackbar Snackbar

<PageTitle>Quản lý Seller</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6 animate-fade-in-up">
    <div class="gradient-icon mr-3">
        <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Size="Size.Large" />
    </div>
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Style="font-weight:800; letter-spacing: -0.5px">👥 Quản lý Người bán (Seller)</MudText>
        <MudText Typo="Typo.body2" Style="color: #64748b; font-weight: 500">Duyệt và quản lý tài khoản đối tác cung cấp dịch vụ trên FoodStreet</MudText>
    </MudStack>
</MudStack>

<!-- Filters -->
<MudPaper Class="glass-card pa-4 mb-6 border-0 animate-fade-in-up delay-1" Elevation="0">
    <MudGrid AlignItems="AlignItems.Center">
        <MudItem xs="12" md="5">
            <MudTextField @bind-Value="_search" Label="Tìm theo tên, email..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Dense="true" Immediate="true"
                          Style="background: rgba(255,255,255,0.5); border-radius: 10px" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect @bind-Value="_filterStatus" Label="Trạng thái tài khoản" Variant="Variant.Outlined" Dense="true"
                        Style="background: rgba(255,255,255,0.5); border-radius: 10px">
                <MudSelectItem Value="@("All")">Tất cả</MudSelectItem>
                <MudSelectItem Value="@("Active")">Đang hoạt động</MudSelectItem>
                <MudSelectItem Value="@("Pending")">Chờ phê duyệt</MudSelectItem>
                <MudSelectItem Value="@("Disabled")">Vô hiệu hóa</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-center justify-end">
             <div class="px-4 py-2" style="background: rgba(16, 185, 129, 0.1); border-radius: 20px; color: #059669">
                <MudText Typo="Typo.body2" Style="font-weight:700">
                    <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mr-1" />
                    @Filtered.Count() Sellers
                </MudText>
             </div>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
}

<MudPaper Elevation="0" Class="glass-card overflow-hidden border-0 animate-fade-in-up delay-2">
    <MudTable Items="@Filtered" Hover="true" Dense="true" Elevation="0" Class="transparent-table"
              Loading="@_loading">
        <HeaderContent>
            <MudTh Style="font-weight:700">Người bán</MudTh>
            <MudTh Style="font-weight:700">Liên hệ</MudTh>
            <MudTh Style="font-weight:700">Trạng thái</MudTh>
            <MudTh Style="font-weight:700">Gian hàng</MudTh>
            <MudTh Style="font-weight:700">Ngày đăng ký</MudTh>
            <MudTh Style="font-weight:700">Thao tác</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudAvatar Style="background: var(--primary-gradient); color: white; border-radius: 12px">
                        @(string.IsNullOrEmpty(context.FullName) ? "?" : context.FullName[0].ToString().ToUpper())
                    </MudAvatar>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2" Style="font-weight:700; color: #1e293b">@context.FullName</MudText>
                        <MudText Typo="Typo.caption" Style="color: #64748b">ID: #@context.Id</MudText>
                    </MudStack>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.body2" Style="font-weight:500; color: #1e293b">@context.Email</MudText>
                    <MudText Typo="Typo.caption" Style="color: #64748b">@context.Phone</MudText>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                         Color="@StatusColor(context.Status)" Style="font-weight:700; border-radius: 8px">
                    @context.Status.ToUpper()
                </MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Style="font-weight:700">
                    @context.StoreCount Shop
                </MudChip>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.body2" Style="color: #64748b; font-weight:500">@context.RegisteredAt.ToString("dd/MM/yyyy")</MudText>
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="0">
                    <MudIconButton Icon="@Icons.Material.Rounded.Visibility" Size="Size.Small"
                                   Color="Color.Info" OnClick="@(() => ViewDetail(context))"
                                   Title="Xem chi tiết" />
                    @if (context.Status == "Pending")
                    {
                        <MudIconButton Icon="@Icons.Material.Rounded.CheckCircle" Size="Size.Small"
                                       Color="Color.Success" Title="Duyệt"
                                       OnClick="@(async () => await SetStatus(context, "Active"))" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Cancel" Size="Size.Small"
                                       Color="Color.Error" Title="Từ chối"
                                       OnClick="@(async () => await SetStatus(context, "Disabled"))" />
                    }
                    else if (context.Status == "Active")
                    {
                        <MudIconButton Icon="@Icons.Material.Rounded.Block" Size="Size.Small"
                                       Color="Color.Warning" Title="Vô hiệu hóa"
                                       OnClick="@(async () => await SetStatus(context, "Disabled"))" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Rounded.LockOpen" Size="Size.Small"
                                       Color="Color.Success" Title="Kích hoạt lại"
                                       OnClick="@(async () => await SetStatus(context, "Active"))" />
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[]{10,25,50}" />
        </PagerContent>
    </MudTable>
</MudPaper>

<!-- Detail Dialog -->
<MudDialog @bind-Visible="_showDetail"
           Options="@(new DialogOptions{MaxWidth=MaxWidth.Large,FullWidth=true})">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Class="mr-2" />
            Chi tiết Seller: @_selected?.FullName
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_selected != null)
        {
            <MudGrid Class="mb-3">
                <MudItem xs="12" md="4">
                    <MudText Typo="Typo.body2"><b>Email:</b> @_selected.Email</MudText>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudText Typo="Typo.body2"><b>Phone:</b> @_selected.Phone</MudText>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudText Typo="Typo.body2"><b>Trạng thái:</b>
                        <MudChip T="string" Size="Size.Small" Color="@StatusColor(_selected.Status)">
                            @_selected.Status
                        </MudChip>
                    </MudText>
                </MudItem>
            </MudGrid>
            <MudText Typo="Typo.subtitle1" Style="font-weight:600" Class="mb-2">
                🏪 Danh sách gian hàng
            </MudText>
            <MudTable Items="@_selected.Stores" Dense="true" Striped="true" Hover="true">
                <HeaderContent>
                    <MudTh>Tên</MudTh>
                    <MudTh>Danh mục</MudTh>
                    <MudTh>Địa chỉ</MudTh>
                    <MudTh>Trạng thái</MudTh>
                    <MudTh>Audio</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>@context.Category</MudTd>
                    <MudTd>@context.Address</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        @if (!string.IsNullOrEmpty(context.AudioUrl))
                        { <MudIcon Icon="@Icons.Material.Filled.Audiotrack" Color="Color.Info" Size="Size.Small" /> }
                        else
                        { <MudText Typo="Typo.caption" Color="Color.Secondary">Không có</MudText> }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showDetail = false)" Variant="Variant.Outlined">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = true, _showDetail;
    private string _search = "", _filterStatus = "All";
    private List<SellerModel> _sellers = new();
    private SellerModel? _selected;

    private IEnumerable<SellerModel> Filtered => _sellers.Where(s =>
        (string.IsNullOrEmpty(_search) ||
         s.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         s.Email.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (_filterStatus == "All" || s.Status == _filterStatus));

    private Color StatusColor(string s) => s switch
    { "Active" => Color.Success, "Pending" => Color.Warning, _ => Color.Error };

    protected override async Task OnInitializedAsync()
    {
        _sellers = await StoreSvc.GetSellersAsync();
        _loading = false;
    }

    private void ViewDetail(SellerModel s) { _selected = s; _showDetail = true; }

    private async Task SetStatus(SellerModel s, string status)
    {
        var ok = await StoreSvc.UpdateSellerStatusAsync(s.Id, status);
        if (ok) { s.Status = status; Snackbar.Add($"Đã cập nhật trạng thái: {status}", Severity.Success); }
        else Snackbar.Add("Lỗi cập nhật!", Severity.Error);
    }
}
