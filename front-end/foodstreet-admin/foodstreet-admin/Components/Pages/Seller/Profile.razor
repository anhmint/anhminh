@page "/seller/profile"
@layout SellerLayout
@rendermode InteractiveServer
@inject AuthService AuthSvc
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Cài đặt Profile</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6 animate-fade-in-up">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h4" Style="font-weight:800">👤 <span class="gradient-text-safe">Cài đặt Profile</span></MudText>
        <MudText Typo="Typo.body2" Style="opacity:0.6">Quản lý thông tin cá nhân</MudText>
    </MudStack>
</MudStack>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-5 text-center mb-4 glass-card animate-fade-in-up" Elevation="0">
            <MudAvatar Style="width:90px;height:90px;font-size:2.5rem;margin:0 auto 12px" Color="Color.Primary">
                @(_name.Length > 0 ? _name[0] : 'U')
            </MudAvatar>
            <MudText Typo="Typo.h6" Style="font-weight:600">@_name</MudText>
            <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mt-1">Seller</MudChip>
            <MudDivider Class="my-3" />
            <MudStack Spacing="1" align-items="AlignItems.Start">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-1" />
                    Đăng ký: 15/01/2025
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Small" Class="mr-1" />
                    2 gian hàng đang hoạt động
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-4 glass-card animate-fade-in-up delay-1" Elevation="0">
            <MudText Typo="Typo.subtitle2" Style="font-weight:600" Class="mb-3">📋 Lịch sử đăng ký</MudText>
            @foreach (var log in _logs)
            {
                <MudStack Row="true" align-items="AlignItems.Start" Class="mb-3" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord"
                             Size="Size.Small" Color="Color.Primary" Style="margin-top:3px;font-size:10px" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2">@log.Item1</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@log.Item2</MudText>
                    </MudStack>
                </MudStack>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="8">
        <!-- Personal Info -->
        <MudPaper Class="pa-5 mb-4 glass-card animate-fade-in-up delay-2" Elevation="0">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600" Class="mb-4">✏️ Thông tin cá nhân</MudText>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_name" Label="Họ và tên" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                                  InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_phone" Label="Số điện thoại" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Value="@("Seller")" Label="Vai trò" Variant="Variant.Outlined" ReadOnly="true" />
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4"
                       StartIcon="@Icons.Material.Filled.Save" OnClick="SaveProfile"
                       Disabled="_savingProfile" Style="border-radius:12px; box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3)">
                @if (_savingProfile) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Lưu thông tin
            </MudButton>
        </MudPaper>

        <!-- Change Password -->
        <MudPaper Class="pa-5 glass-card animate-fade-in-up delay-3" Elevation="0">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600" Class="mb-4">🔑 Đổi mật khẩu</MudText>
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_curPwd" Label="Mật khẩu hiện tại"
                                  InputType="InputType.Password" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_newPwd" Label="Mật khẩu mới"
                                  InputType="InputType.Password" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_confirmPwd" Label="Xác nhận mật khẩu mới"
                                  InputType="InputType.Password" Variant="Variant.Outlined"
                                  Error="@(_newPwd != _confirmPwd && _confirmPwd.Length > 0)"
                                  ErrorText="Mật khẩu không khớp" />
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Class="mt-4"
                       StartIcon="@Icons.Material.Filled.Lock" OnClick="ChangePwd"
                       Disabled="_savingPwd" Style="border-radius:12px">
                @if (_savingPwd) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Đổi mật khẩu
            </MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string _name = "";
    private string _email = "";
    private string _phone = "";
    private string _curPwd = "", _newPwd = "", _confirmPwd = "";
    private bool _savingProfile, _savingPwd;
    
    // Biến lưu trữ ID thật của người dùng
    private int _currentUserId = 0;

    private List<(string, string)> _logs = new();

    protected override async Task OnInitializedAsync()
    {
        // Prefer fetching fresh profile from API (cookie claims may be stale after updates).
        var (ok, me, _) = await AuthSvc.GetMeAsync();
        if (ok && me != null)
        {
            _currentUserId = me.Id;
            _name = me.FullName;
            _email = me.Email;
            _phone = me.Phone; // currently not persisted on backend; kept for future
            return;
        }

        // Fallback: show from cookie claims (for initial render if API not reachable).
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _email = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
            _name = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? _email;

            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (idClaim != null && int.TryParse(idClaim.Value, out int parsedId))
                _currentUserId = parsedId;
        }
    }

    private async Task SaveProfile()
    {
        if (_currentUserId == 0) 
        {
            Snackbar.Add("Lỗi: Không nhận diện được ID tài khoản của bạn!", Severity.Error);
            return;
        }
        
        _savingProfile = true;
        
        var (ok, msg) = await AuthSvc.UpdateProfileAsync(_currentUserId, _name, _email);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok)
        {
            // Refresh UI with the latest data from backend
            var (meOk, me, _) = await AuthSvc.GetMeAsync();
            if (meOk && me != null)
            {
                _name = me.FullName;
                _email = me.Email;
            }
        }
        
        _savingProfile = false;
    }

    private async Task ChangePwd()
    {
        if (string.IsNullOrEmpty(_curPwd) || _newPwd != _confirmPwd)
        { 
            Snackbar.Add("Mật khẩu không hợp lệ hoặc không khớp!", Severity.Error); 
            return; 
        }
        
        if (_currentUserId == 0) return;

        _savingPwd = true;
        
        // Truyền _currentUserId thật vào, thay vì số 1 gõ cứng
        var (ok, msg) = await AuthSvc.ChangePasswordAsync(_currentUserId, _curPwd, _newPwd);
        
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) _curPwd = _newPwd = _confirmPwd = "";
        
        _savingPwd = false;
    }
}