@rendermode InteractiveServer

<MudThemeProvider Theme="@_theme" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Medium" CloseOnEscapeKey="true" />
<MudSnackbarProvider />

@code {
    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary        = "#1565C0",
            PrimaryDarken  = "#003c8f",
            PrimaryLighten = "#5e92f3",
            Secondary      = "#6A1B9A",
            Success        = "#2E7D32",
            Warning        = "#E65100",
            Error          = "#B71C1C",
            Info           = "#01579B",
            AppbarBackground = "#1565C0",
            DrawerBackground = "#FAFAFA",
            Background     = "#F0F2F5",
            Surface        = "#FFFFFF",
        }
    };
}
