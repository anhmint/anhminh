<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== PRIMARY PALETTE ===== -->
    <!-- Cam nóng - màu chủ đạo -->
    <Color x:Key="Primary">#FF6B35</Color>
    <Color x:Key="PrimaryLight">#FF8C5A</Color>
    <Color x:Key="PrimaryDark">#E85520</Color>

    <!-- Vàng kem - màu phụ -->
    <Color x:Key="Secondary">#F7C59F</Color>
    <Color x:Key="SecondaryLight">#FDDFC4</Color>
    <Color x:Key="SecondaryDark">#E8A870</Color>

    <!-- Accent - Vàng nghệ -->
    <Color x:Key="Accent">#FFB800</Color>

    <!-- ===== NEUTRAL PALETTE ===== -->
    <Color x:Key="Background">#FFF8F0</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceVariant">#FFF0E6</Color>

    <!-- Nâu đất - text chính -->
    <Color x:Key="OnBackground">#2C1A0E</Color>
    <Color x:Key="OnSurface">#3D2B1F</Color>
    <Color x:Key="OnSurfaceVariant">#7A5C4A</Color>

    <!-- Text phụ -->
    <Color x:Key="TextPrimary">#2C1A0E</Color>
    <Color x:Key="TextSecondary">#7A5C4A</Color>
    <Color x:Key="TextHint">#B5917A</Color>

    <!-- ===== SEMANTIC COLORS ===== -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Info">#2196F3</Color>

    <!-- ===== BORDER & DIVIDER ===== -->
    <Color x:Key="Border">#F0D9C8</Color>
    <Color x:Key="Divider">#F5E6D8</Color>

    <!-- ===== OVERLAY ===== -->
    <Color x:Key="Overlay">#A02C1A0E</Color>
    <Color x:Key="CardShadow">#20FF6B35</Color>

    <!-- ===== SPECIFIC ===== -->
    <Color x:Key="NavBarBackground">#FFFFFF</Color>
    <Color x:Key="TabBarBackground">#FFFFFF</Color>
    <Color x:Key="PlayerBackground">#2C1A0E</Color>
    <Color x:Key="PlayerSurface">#3D2B1F</Color>

</ResourceDictionary>