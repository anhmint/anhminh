<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.AudioPlayerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PlayerBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── TOP BAR ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,52,16,16">
            <!-- Back -->
            <Button Grid.Column="0"
                    Text="↙"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="#30FFFFFF"
                    TextColor="White"
                    FontSize="20"
                    CornerRadius="22"
                    WidthRequest="44" HeightRequest="44"
                    Padding="0"/>

            <!-- "Đang phát" label -->
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Label Text="ĐANG PHÁT"
                       FontFamily="PoppinsSemiBold"
                       FontSize="11"
                       TextColor="#80FFFFFF"
                       HorizontalOptions="Center"
                       CharacterSpacing="2"/>
                <Label Text="Thuyết minh ẩm thực"
                       Style="{StaticResource BodySmall}"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Speed button -->
            <Border Grid.Column="2"
                    BackgroundColor="#30FFFFFF"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    Padding="10,6">
                <Button Text="{Binding PlaybackSpeed, StringFormat='{0}x'}"
                        Command="{Binding CycleSpeedCommand}"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontFamily="PoppinsSemiBold"
                        FontSize="14"
                        Padding="0"
                        HeightRequest="32"/>
            </Border>
        </Grid>

        <!-- ── PLAYER CENTER CONTENT ── -->
        <VerticalStackLayout Grid.Row="1"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="0"
                             Padding="28,0">

            <!-- Album Art / POI Image -->
            <Border StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    WidthRequest="280" HeightRequest="280"
                    HorizontalOptions="Center"
                    Margin="0,0,0,32">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,8" Radius="32" Opacity="0.4"/>
                </Border.Shadow>
                <Image Source="{Binding ImageUrl}"
                       Aspect="AspectFill"
                       WidthRequest="280"
                       HeightRequest="280"/>
            </Border>

            <!-- POI Name & Guide Title -->
            <Label Text="{Binding POIName}"
                   Style="{StaticResource HeadlineSmall}"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,6"/>
            <Label Text="{Binding GuideTitle}"
                   Style="{StaticResource BodyMedium}"
                   TextColor="#AAFFFFFF"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="TailTruncation"
                   MaxLines="2"
                   Margin="0,0,0,32"/>

            <!-- ── PROGRESS BAR ── -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Fill">
                <Slider Value="{Binding Progress}"
                        Minimum="0" Maximum="1"
                        MinimumTrackColor="{StaticResource Primary}"
                        MaximumTrackColor="#30FFFFFF"
                        ThumbColor="White"/>

                <Grid ColumnDefinitions="*,*">
                    <Label Grid.Column="0"
                           Text="{Binding PositionText}"
                           Style="{StaticResource BodySmall}"
                           TextColor="#AAFFFFFF"/>
                    <Label Grid.Column="1"
                           Text="{Binding DurationText}"
                           Style="{StaticResource BodySmall}"
                           TextColor="#AAFFFFFF"
                           HorizontalOptions="End"/>
                </Grid>
            </VerticalStackLayout>

            <!-- ── CONTROLS ── -->
            <Grid ColumnDefinitions="*,Auto,*"
                  HorizontalOptions="Fill"
                  Margin="0,24,0,0">

                <!-- Rewind 10s -->
                <Button Grid.Column="0"
                        Text="⏪"
                        Command="{Binding SeekBackwardCommand}"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="28"
                        Padding="0"
                        HorizontalOptions="Center"/>

                <!-- Play/Pause (main button) -->
                <Border Grid.Column="1"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 38"
                        StrokeThickness="0"
                        WidthRequest="76" HeightRequest="76"
                        HorizontalOptions="Center">
                    <Border.Shadow>
                        <Shadow Brush="White" Offset="0,4" Radius="16" Opacity="0.3"/>
                    </Border.Shadow>
                    <Button x:Name="PlayPauseBtn"
                            Command="{Binding TogglePlayPauseCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            FontSize="32"
                            WidthRequest="76" HeightRequest="76"
                            Padding="0"/>
                </Border>

                <!-- Forward 10s -->
                <Button Grid.Column="2"
                        Text="⏩"
                        Command="{Binding SeekForwardCommand}"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="28"
                        Padding="0"
                        HorizontalOptions="Center"/>
            </Grid>

        </VerticalStackLayout>

        <!-- ── DESCRIPTION BOTTOM CARD ── -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource PlayerSurface}"
                StrokeShape="RoundRectangle 24,24,0,0"
                StrokeThickness="0"
                Padding="24,20,24,36">
            <VerticalStackLayout Spacing="8">
                <Label Text="Nội dung thuyết minh"
                       Style="{StaticResource TitleMedium}"
                       TextColor="White"/>
                <ScrollView HeightRequest="80">
                    <Label Text="{Binding AudioGuide.Description}"
                           Style="{StaticResource BodySmall}"
                           TextColor="#AAFFFFFF"
                           LineBreakMode="WordWrap"/>
                </ScrollView>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
