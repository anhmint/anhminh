<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <Grid RowDefinitions="Auto,*,Auto" MinimumHeightRequest="600">

            <!-- ── TOP DECORATIVE AREA ── -->
            <Grid Grid.Row="0" HeightRequest="280" BackgroundColor="{StaticResource Primary}">

                <!-- Background gradient overlay -->
                <BoxView Color="{StaticResource PrimaryDark}" Opacity="0.3"
                         HorizontalOptions="Fill" VerticalOptions="Fill"/>

                <!-- Decorative circles -->
                <Ellipse Fill="{StaticResource PrimaryLight}" Opacity="0.2"
                         WidthRequest="200" HeightRequest="200"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="0,-60,-60,0"/>
                <Ellipse Fill="{StaticResource Secondary}" Opacity="0.15"
                         WidthRequest="150" HeightRequest="150"
                         HorizontalOptions="Start" VerticalOptions="End"
                         Margin="-40,0,0,20"/>

                <!-- Logo & Title -->
                <VerticalStackLayout
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Spacing="12" Padding="0,40,0,0">

                    <!-- Food Icon -->
                    <Border BackgroundColor="White" Opacity="0.95"
                            StrokeShape="RoundRectangle 20"
                            WidthRequest="80" HeightRequest="80"
                            StrokeThickness="0"
                            HorizontalOptions="Center">
                        <Label Text="🍜"
                               FontSize="40"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Margin="10"/>
                    </Border>

                    <Label Text="FoodTour POI"
                           Style="{StaticResource HeadlineMedium}"
                           TextColor="White"
                           HorizontalOptions="Center"
                           FontFamily="PoppinsBold"/>

                    <Label Text="Khám phá ẩm thực địa phương"
                           Style="{StaticResource BodyMedium}"
                           TextColor="#E8FFFFFF"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- ── LOGIN FORM CARD ── -->
            <Border Grid.Row="1"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 28,28,0,0"
                    StrokeThickness="0"
                    Margin="0,-28,0,0"
                    Padding="28,36,28,20">

                <VerticalStackLayout Spacing="0">

                    <Label Text="Đăng nhập"
                           Style="{StaticResource HeadlineSmall}"
                           Margin="0,0,0,4"/>

                    <Label Text="Đăng nhập để bắt đầu khám phá"
                           Style="{StaticResource BodySmall}"
                           Margin="0,0,0,28"/>

                    <!-- Error Banner -->
                    <Border BackgroundColor="#FFF3F3"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            Padding="14,12"
                            Margin="0,0,0,16"
                            IsVisible="{Binding HasError}">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⚠️" FontSize="16" VerticalOptions="Center"/>
                            <Label Text="{Binding ErrorMessage}"
                                   Style="{StaticResource BodySmall}"
                                   TextColor="{StaticResource Error}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Email Field -->
                    <Label Text="Email" Style="{StaticResource TitleMedium}" Margin="0,0,0,6"/>
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1.5"
                            Stroke="{StaticResource Border}"
                            Padding="16,4"
                            Margin="0,0,0,16">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   x:Name="EmailEntry"
                                   Style="{StaticResource InputEntry}"
                                   Placeholder="email@example.com"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   ReturnType="Next"/>
                            <Label Grid.Column="1" Text="📧" FontSize="18"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Password Field -->
                    <Label Text="Mật khẩu" Style="{StaticResource TitleMedium}" Margin="0,0,0,6"/>
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1.5"
                            Stroke="{StaticResource Border}"
                            Padding="16,4"
                            Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   Style="{StaticResource InputEntry}"
                                   Placeholder="Nhập mật khẩu"
                                   Text="{Binding Password}"
                                   IsPassword="{Binding IsPasswordVisible, Converter={StaticResource BoolInverterConverter}}"
                                   ReturnType="Done"
                                   ReturnCommand="{Binding LoginCommand}"/>
                            <Button Grid.Column="1"
                                    Text="👁️"
                                    Command="{Binding TogglePasswordVisibilityCommand}"
                                    Style="{StaticResource IconButton}"
                                    FontSize="18"/>
                        </Grid>
                    </Border>

                    <!-- Hint text -->
                    <!--<Label Text="Demo: user@foodtour.vn / 123456"
                           Style="{StaticResource LabelCaption}"
                           TextColor="{StaticResource TextHint}"
                           HorizontalOptions="End"
                           Margin="0,0,0,28"/>-->

                    <!-- Login Button -->
                    <Button Text="Đăng nhập"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}"
                            HorizontalOptions="Fill"/>

                    <!-- Loading Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       HorizontalOptions="Center"
                                       Margin="0,16,0,0"/>

                </VerticalStackLayout>
            </Border>

            <!-- ── FOOTER ── -->
            <VerticalStackLayout Grid.Row="2"
                                 Padding="28,12"
                                 BackgroundColor="{StaticResource Surface}">
                
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,0,0,16">
                    <Label Text="Chưa có tài khoản?" Style="{StaticResource BodyMedium}" />
                    <Label Text="Đăng ký ngay" TextColor="{StaticResource Primary}" Style="{StaticResource TitleMedium}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToRegisterCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <Label Text="© 2026 FoodTour POI · Khám phá ẩm thực"
                       Style="{StaticResource LabelCaption}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>
