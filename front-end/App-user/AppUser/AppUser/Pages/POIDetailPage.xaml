<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppUser.Pages.POIDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AppUser.ViewModels"
    xmlns:models="clr-namespace:AppUser.Models"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- ── HERO IMAGE ── -->
                <Grid HeightRequest="380">
                    <Image Source="{Binding POI.ImageUrl}"
                           Aspect="AspectFill"
                           HeightRequest="380"
                           HorizontalOptions="Fill"/>

                    <!-- Dark gradient overlay -->
                    <BoxView HorizontalOptions="Fill" VerticalOptions="Fill">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#40000000" Offset="0" />
                                <GradientStop Color="#80000000" Offset="0.6" />
                                <GradientStop Color="#D0000000" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Back button -->
                    <Border BackgroundColor="#80000000"
                            StrokeShape="RoundRectangle 22"
                            StrokeThickness="0"
                            WidthRequest="44" HeightRequest="44"
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            Margin="16,48,0,0">
                        <Button Text="←"
                                Command="{Binding GoBackCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="20"
                                Padding="0"
                                WidthRequest="44" HeightRequest="44"/>
                    </Border>

                    <!-- Language toggle -->
                    <Border BackgroundColor="#80000000"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0"
                            Padding="10,6"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,52,16,0">
                        <Button Text="{Binding CurrentLanguage, StringFormat='🌐 {0}'}"
                                Command="{Binding ToggleLanguageCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontFamily="PoppinsSemiBold"
                                FontSize="13"
                                Padding="0"
                                HeightRequest="32"/>
                    </Border>

                    <!-- POI Name on image -->
                    <VerticalStackLayout VerticalOptions="End"
                                         HorizontalOptions="Start"
                                         Padding="20,16">
                        <Label Text="{Binding DisplayName}"
                               Style="{StaticResource HeadlineMedium}"
                               TextColor="White"
                               LineBreakMode="WordWrap"/>
                        <HorizontalStackLayout Spacing="6" Margin="0,4,0,0">
                            <Label Text="📍" FontSize="14" TextColor="White"/>
                            <Label Text="{Binding POI.Location}"
                                   Style="{StaticResource BodyMedium}"
                                   TextColor="#DDFFFFFF"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- ── MAIN CONTENT CARD ── -->
                <Border BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 24,24,0,0"
                        StrokeThickness="0"
                        Margin="0,-24,0,0"
                        Padding="20,24,20,20">

                    <VerticalStackLayout Spacing="20">

                        <!-- ── AUDIO PLAYER PREVIEW ── -->
                        <Border BackgroundColor="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 16"
                                StrokeThickness="0"
                                Padding="16,14"
                                IsVisible="{Binding HasAudio}">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="🎧 Thuyết minh audio"
                                           Style="{StaticResource TitleMedium}"
                                           TextColor="White"/>
                                    <Label Text="{Binding CurrentAudioGuide.Title}"
                                           Style="{StaticResource BodySmall}"
                                           TextColor="#DDFFFFFF"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"/>
                                    <Label Text="{Binding CurrentAudioGuide.DurationDisplay, StringFormat='⏱️ {0}'}"
                                           Style="{StaticResource LabelCaption}"
                                           TextColor="#AAFFFFFF"/>
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="▶ Nghe"
                                        Command="{Binding PlayAudioCommand}"
                                        BackgroundColor="White"
                                        TextColor="{StaticResource Primary}"
                                        FontFamily="PoppinsBold"
                                        FontSize="14"
                                        CornerRadius="10"
                                        HeightRequest="40"
                                        Padding="14,0"/>
                            </Grid>
                        </Border>

                        <!-- No audio state -->
                        <Border BackgroundColor="{StaticResource SurfaceVariant}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                Padding="16,12"
                                IsVisible="{Binding HasAudio, Converter={StaticResource BoolInverterConverter}}">
                            <Label Text="🔇 Chưa có audio thuyết minh cho ngôn ngữ này"
                                   Style="{StaticResource BodySmall}"
                                   TextColor="{StaticResource TextHint}"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <!-- ── DIVIDER ── -->
                        <BoxView Style="{StaticResource Divider}"/>

                        <!-- ── DESCRIPTION ── -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Giới thiệu"
                                   Style="{StaticResource HeadlineSmall}"/>
                            <Label Text="{Binding DisplayDescription}"
                                   Style="{StaticResource BodyLarge}"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>

                        <!-- ── DIVIDER ── -->
                        <BoxView Style="{StaticResource Divider}"/>

                        <!-- ── MENU SECTION ── -->
                        <VerticalStackLayout Spacing="12">
                            <Label Text="🍽️ Thực đơn"
                                   Style="{StaticResource HeadlineSmall}"/>

                            <!-- Menu Groups -->
                            <CollectionView ItemsSource="{Binding POI.Shop.Menus}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:MenuDto">
                                        <VerticalStackLayout Spacing="8" Margin="0,0,0,16">

                                            <!-- Menu name -->
                                            <Label Text="{Binding Name}"
                                                   Style="{StaticResource TitleLarge}"
                                                   TextColor="{StaticResource Primary}"/>

                                            <!-- Menu Items -->
                                            <CollectionView ItemsSource="{Binding Items}"
                                                            SelectionMode="None">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:MenuItemDto">
                                                        <Border BackgroundColor="{StaticResource Surface}"
                                                                StrokeShape="RoundRectangle 16"
                                                                StrokeThickness="0"
                                                                Margin="0,6,0,8"
                                                                Padding="16,16">
                                                            <Border.Shadow>
                                                                <Shadow Brush="#15000000" Offset="0,4" Radius="10" Opacity="1"/>
                                                            </Border.Shadow>
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                                    <Label Text="{Binding Name}"
                                                                           FontFamily="PoppinsBold" FontSize="16" TextColor="{StaticResource TextPrimary}"/>
                                                                    <Label Text="{Binding Description}"
                                                                           FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}"
                                                                           LineBreakMode="TailTruncation"
                                                                           MaxLines="2"/>
                                                                </VerticalStackLayout>
                                                                <VerticalStackLayout Grid.Column="1"
                                                                                     HorizontalOptions="End"
                                                                                     VerticalOptions="Center" Spacing="2">
                                                                    <Label Text="{Binding PriceDisplay}"
                                                                           FontFamily="PoppinsSemiBold" FontSize="16"
                                                                           TextColor="{StaticResource Primary}"
                                                                           HorizontalOptions="End"/>
                                                                    <Border BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="8,4" IsVisible="{Binding IsAvailable}" HorizontalOptions="End">
                                                                        <Label Text="Còn hàng" FontFamily="PoppinsMedium" FontSize="10" TextColor="{StaticResource Success}"/>
                                                                    </Border>
                                                                </VerticalStackLayout>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Bottom padding -->
                <BoxView HeightRequest="32" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── FLOATING PLAY BUTTON ── -->
        <Border StrokeShape="RoundRectangle 24"
                StrokeThickness="0"
                IsVisible="{Binding HasAudio}"
                HorizontalOptions="Fill"
                VerticalOptions="End"
                Margin="20,0,20,32"
                HeightRequest="56">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="{StaticResource PrimaryDark}" Offset="0,10" Radius="20" Opacity="0.5"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding PlayAudioCommand}" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <Label Text="🎧" FontSize="24" TextColor="White" VerticalOptions="Center"/>
                <Label Text="Nghe thuyết minh ngay" FontFamily="PoppinsBold" FontSize="16" TextColor="White" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentPage>
